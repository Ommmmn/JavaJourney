{
  "info": {
    "name": "PetyMate API",
    "_postman_id": "petymate-collection-2024",
    "description": "Complete API collection for PetyMate — India's One-Stop Pet Platform.\n\nBase URL: {{baseUrl}}\nAuth: Bearer {{token}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "petId", "value": "", "type": "string" },
    { "key": "matchId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "vetId", "value": "", "type": "string" },
    { "key": "trainerId", "value": "", "type": "string" },
    { "key": "packageId", "value": "", "type": "string" }
